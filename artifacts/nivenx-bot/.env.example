# NivenX Assistant - Environment Variables
# Copy this file to .env and fill in your values.
# In Replit, these are set as Secrets — no .env file needed.

# ── Discord Credentials (required) ──────────────────────────────
# Get these from https://discord.com/developers/applications

# Your bot token (Bot → Token)
DISCORD_TOKEN=your_bot_token_here

# Your application (client) ID (General Information → Application ID)
DISCORD_CLIENT_ID=your_client_id_here

# Your server (guild) ID for guild-specific command deployment
# (Right-click your server with Developer Mode on → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# ── Optional Configuration ───────────────────────────────────────
# These have defaults in src/config/config.js

# NODE_ENV=production
